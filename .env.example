# Local secrets — copy this file to `.env` and fill in values from the course
# Google Doc design brief (Azure OpenAI / API section). Do not commit `.env`.

# Azure OpenAI resource base URL only (from the design brief) — not the full /chat/completions path.
# Example: https://your-resource.openai.azure.com/
AZURE_OPENAI_ENDPOINT=

# API key for that resource (from the design brief).
AZURE_OPENAI_API_KEY=

# API version — use the value specified in the design brief if it differs.
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Deployment name in Azure (often matches the model deployment; design brief may call this out).
AZURE_OPENAI_DEPLOYMENT_NAME=o4-mini

# Optional: backend port (default 3001; avoids macOS AirPlay using 5000).
# FLASK_PORT=3001

# Optional: where the React app calls the chat API (default http://localhost:3001).
# On GitHub Codespaces, use the forwarded URL for port 3001, e.g. https://….app.github.dev
# REACT_APP_CHAT_API=
